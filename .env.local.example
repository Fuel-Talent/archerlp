# Sanity CMS — get these from sanity.io/manage after creating a free project.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Write token for the seed script. Create at sanity.io/manage → API → Tokens
# with "Editor" role. Never commit this. Only needed locally for npm run sanity:seed.
SANITY_WRITE_TOKEN=

# Resend autoresponder — required for /api/submit to push form submissions
# into a Resend audience. Create at resend.com → API Keys.
RESEND_API_KEY=

# Optional: notification email recipient + sender for the team alert that
# fires when a form is submitted. If unset, contact still goes to the audience
# but no team notification is sent. The from address must be on a verified
# Resend domain.
LEAD_NOTIFICATION_TO=
LEAD_NOTIFICATION_FROM=
